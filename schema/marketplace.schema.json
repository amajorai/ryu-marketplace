{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/amajorai/ryu-marketplace/HEAD/schema/marketplace.schema.json",
  "title": "Ryu marketplace manifest",
  "type": "object",
  "required": ["plugins"],
  "properties": {
    "name": { "type": "string", "description": "Marketplace identity (kebab-case)" },
    "owner": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      },
      "required": ["name"],
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/definitions/plugin" }
    }
  },
  "additionalProperties": true,
  "definitions": {
    "plugin": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "id": { "type": "string", "description": "Reverse-DNS unique id" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "tagline": { "type": "string", "maxLength": 80 },
        "description": { "type": "string" },
        "source": {
          "description": "owner/repo, a git URL, or the literal \"builtin\"",
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "object",
              "properties": {
                "repo": { "type": "string" },
                "url": { "type": "string" },
                "source": { "type": "string" }
              },
              "additionalProperties": true
            }
          ]
        },
        "builtin": { "type": "boolean" },
        "developer": { "type": "string" },
        "author": {
          "oneOf": [
            { "type": "string" },
            { "type": "object", "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "url": { "type": "string" } } }
          ]
        },
        "category": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "iconUrl": { "type": "string", "format": "uri" },
        "screenshots": { "type": "array", "items": { "type": "string", "format": "uri" }, "maxItems": 8 },
        "examplePrompts": { "type": "array", "items": { "type": "string" }, "maxItems": 8 },
        "homepage": { "type": "string", "format": "uri" },
        "privacyPolicyUrl": { "type": "string", "format": "uri" },
        "termsOfServiceUrl": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "skills": { "type": "array", "items": {} },
        "setup": {
          "oneOf": [
            { "$ref": "#/definitions/setupStep" },
            { "type": "array", "items": { "$ref": "#/definitions/setupStep" } }
          ]
        }
      },
      "additionalProperties": true
    },
    "setupStep": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "actionLabel": { "type": "string" },
        "actionUrl": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    }
  }
}
